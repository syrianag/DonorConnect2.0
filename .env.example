# Copy this file to `.env` and set DATABASE_URL appropriately before running Prisma CLI.

# Example: Neon Postgres (replace placeholders, do NOT commit secrets)
# DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require&channel_binding=require"

# Quick local dev using SQLite (safe to commit for local development)
# DATABASE_URL="file:./dev.db"

# If you prefer to use Neon, set the real URL in your environment or in `.env`.

